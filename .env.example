# API Settings
API_V1_STR=/api/v1
PROJECT_NAME=RAG API

# Elasticsearch Settings
ELASTICSEARCH_HOST=http://localhost:9200
ELASTICSEARCH_INDEX=documents

# Embedding Model Settings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Ranker Settings
RANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Retrieval Settings
DENSE_RETRIEVER_TOP_K=10
BM25_RETRIEVER_TOP_K=10
RANKER_TOP_K=5
DEFAULT_QUERY_TOP_K=5

# Document Splitting Settings
SPLIT_BY=word
CHUNK_SIZE=500
CHUNK_OVERLAP=50
